# Server
PORT=5000
NODE_ENV=development

# Supabase Postgres (use the pooled "Transaction" connection string for serverless)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Supabase API (Settings → API in your Supabase dashboard)
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# CORS — must match the URL your frontend runs on
FRONTEND_ORIGIN=http://localhost:5173

# GitHub API Token (Optional, for higher rate limits)
GITHUB_TOKEN=ghp_optional_personal_access_token

# GitHub OAuth App (Required for user connection)
GITHUB_CLIENT_ID=your_client_id
GITHUB_CLIENT_SECRET=your_client_secret
